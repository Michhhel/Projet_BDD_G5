# =============================================================================
# Variables d'environnement ENSEA — copier en .env et adapter localement
# =============================================================================

# Clé secrète Flask (générer : python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=changez-moi-en-production

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ensea_notes

# Configuration mail (laisser vide en dev pour afficher mots de passe en console)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=ENSEA Notes <noreply@ensea.ci>

# Environnement Flask
FLASK_ENV=development
FLASK_DEBUG=1
